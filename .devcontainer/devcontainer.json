{
  "name": "speed-challenge",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "speed-challenge",
  "workspaceFolder": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
